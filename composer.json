{
    "name": "harperagency/openmage-order-customer-tagger",
    "description": "OpenMage (Magento 1) Order & Customer Tagger — rule-based tagging engine with admin CRUD, grid columns, and inline popover",
    "type": "magento-module",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": ["openmage", "magento1", "tagger", "order-tags", "customer-tags"],
    "authors": [
        {
            "name": "Harper Agency",
            "email": "dev@harper.agency",
            "homepage": "https://harper.agency"
        }
    ],
    "require": {
        "php": ">=7.4",
        "magento-hackathon/magento-composer-installer": ">=3.0"
    },
    "extra": {
        "map": [
            ["app/code/community/HarperAgency/OrderCustomerTagger", "app/code/community/HarperAgency/OrderCustomerTagger"],
            ["app/design/adminhtml/default/default/layout/harper_tagger.xml", "app/design/adminhtml/default/default/layout/harper_tagger.xml"],
            ["app/design/adminhtml/default/default/template/harper_tagger", "app/design/adminhtml/default/default/template/harper_tagger"],
            ["app/etc/modules/HarperAgency_OrderCustomerTagger.xml", "app/etc/modules/HarperAgency_OrderCustomerTagger.xml"]
        ]
    }
}
